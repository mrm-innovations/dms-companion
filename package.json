{
  "name": "dms-companion",
  "version": "0.1.4",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm.cmd run dev:main",
    "dev:main": "vite build --watch --mode development",
    "dev:content": "node scripts/build-content.mjs --watch",
    "build": "vite build && node scripts/build-content.mjs",
    "install:local": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/install-local.ps1 -Build",
    "install:local:chrome": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/install-local.ps1 -Build -Browser chrome",
    "package:zip": "npm run test && npm run build && node scripts/package-release.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.314",
    "@types/node": "^24.6.2",
    "esbuild": "^0.25.11",
    "jsdom": "^27.0.0",
    "typescript": "^5.9.3",
    "vite": "^7.1.10",
    "vitest": "^3.2.4"
  }
}
